<h1>Newsletters</h1>

<ul>
{% for post in collections.posts | reverse %}
  <li>
    <a href="{{ post.url }}">
      {{ post.data.title }}
    </a>
    <br>
    <small>{{ post.date | readableDate }}</small>
  </li>
{% endfor %}
</ul>
